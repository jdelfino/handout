# Copy to .env and fill in. .env is gitignored.
# See docs/design/KICKSTART.md → "Required env vars" for full notes.

# --- Required ---
DATABASE_URL=postgres://handout:handout@localhost:5432/handout
APP_BASE_URL=http://localhost:8080
SESSION_SECRET=

# GitHub App credentials (one set per deployment).
# See docs/setup/SELF_HOSTING.md for how to register the App.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_WEBHOOK_SECRET=

# --- Optional ---
PORT=8080
LOG_LEVEL=info
# SECRETS_PROVIDER: env | gcp | aws | vault   (default: env)
SECRETS_PROVIDER=env
# Run schema migrations on container startup. False by default; flip to true
# in containerized deploys where you don't run a separate migrate step.
RUN_MIGRATIONS_ON_STARTUP=false
