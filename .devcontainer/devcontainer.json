{
  "name": "handout",
  "image": "mcr.microsoft.com/devcontainers/base:trixie",

  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/handout,type=bind,consistency=cached",
  "workspaceFolder": "/workspaces/handout",

  "mounts": [
    "source=handout-node-modules,target=/workspaces/handout/node_modules,type=volume",
    "source=${localEnv:HOME}/.claude,target=/home/vscode/.claude,type=bind,consistency=consistent"
  ],

  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": { "moby": false },
    "ghcr.io/devcontainers/features/node:1": { "version": "22", "installYarnUsingApt": false },
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/terraform:1": {}
  },
  "initializeCommand": "./.devcontainer/init-1password.sh",
  "postCreateCommand": "./.devcontainer/post-create.sh",
  "postStartCommand": "./.devcontainer/post-start.sh && ./.devcontainer/setup-secrets.sh",

  "remoteEnv": {
    "BD_SOCKET": "/tmp/beads.sock"
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "planet57.vscode-beads",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode"
      ]
    }
  }
}
